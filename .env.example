# apM Claw Docker Configuration
#
# Quick start:
# 1) Copy this file to `.env` in the project root
# 2) Fill in required values (OPENCLAW_GATEWAY_TOKEN, TELEGRAM_BOT_TOKEN, AI provider)
# 3) Run: docker compose up -d
#
# Keep secrets out of git!

# -----------------------------------------------------------------------------
# Gateway auth (REQUIRED)
# -----------------------------------------------------------------------------
APMCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# -----------------------------------------------------------------------------
# Telegram (REQUIRED for apM Claw)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Get from @BotFather: https://t.me/botfather

# -----------------------------------------------------------------------------
# AI Provider (Choose at least one)
# -----------------------------------------------------------------------------
# Anthropic (recommended for crypto community moderation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...

# Google Gemini (alternative)
# GEMINI_API_KEY=...

# Multiple keys for load balancing (optional)
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# OPENAI_API_KEYS=sk-1,sk-2

# -----------------------------------------------------------------------------
# Web Search (Optional, for news/sentiment monitoring)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...

# -----------------------------------------------------------------------------
# Docker-specific settings
# -----------------------------------------------------------------------------
# Override defaults if needed
# APMCLAW_CONFIG_DIR=./config
# APMCLAW_WORKSPACE_DIR=./workspace
# APMCLAW_GATEWAY_PORT=18789
# APMCLAW_BRIDGE_PORT=18790

# -----------------------------------------------------------------------------
# Advanced (Usually not needed)
# -----------------------------------------------------------------------------
# APMCLAW_GATEWAY_BIND=lan
# APMCLAW_ALLOW_INSECURE_PRIVATE_WS=1
