#!/usr/bin/env bash

# 민감정보 커밋 차단 pre-commit hook
# 설정: git config core.hooksPath git-hooks

set -euo pipefail

# 커밋 금지 파일 패턴
BLOCKED_PATTERNS=(
  '\.pem$'
  '\.env$'
  '\.env\.'
  'CLAUDE\.md$'
  'credentials'
  'secret'
)

# 민감 콘텐츠 패턴 (파일 내용 검사)
SENSITIVE_PATTERNS=(
  'PRIVATE KEY'
  'Bearer [A-Za-z0-9+/=]'
  'ghp_[A-Za-z0-9]'
  'github_pat_[A-Za-z0-9]'
  'sk-[A-Za-z0-9]'
  'AKIA[A-Z0-9]'
)

staged_files=()
while IFS= read -r -d '' file; do
  staged_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#staged_files[@]}" -eq 0 ]; then
  exit 0
fi

blocked=0

# 1. 파일명 패턴 검사
for file in "${staged_files[@]}"; do
  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo "❌ BLOCKED: $file (패턴: $pattern)" >&2
      blocked=1
    fi
  done
done

# 2. 파일 내용 검사 (텍스트 파일만)
for file in "${staged_files[@]}"; do
  if git show ":$file" 2>/dev/null | file - | grep -q text; then
    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
      if git show ":$file" 2>/dev/null | grep -qE "$pattern"; then
        echo "❌ BLOCKED: $file (민감 콘텐츠: $pattern)" >&2
        blocked=1
      fi
    done
  fi
done

if [ "$blocked" -ne 0 ]; then
  echo "" >&2
  echo "민감정보가 포함된 파일이 감지되었습니다." >&2
  echo "의도적이라면: git commit --no-verify" >&2
  exit 1
fi
